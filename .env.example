# GitHub App
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/codeops

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/account/codeops-reviews
AWS_S3_BUCKET=codeops-diffs

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000
